/**
 * 🧠 SELF-LEARNING AUTONOMOUS CONTROL SYSTEM
 * Level: OpenAI / Google / Stripe adaptive learning infra (PRO MAX++)
 */

import { SystemMaturityEngine } from "./system-maturity.engine.js";
import { FeatureFlagEngine } from "./feature-flag.engine.js";

export class SelfLearningAutonomousControlSystem {

  /* =========================
     🧠 SYSTEM STATE
  ========================= */
  static state = {
    lastLevel: "MVP",
    stabilityScore: 100,
    failures: 0,

    history: [],

    thresholds: {
      errorTolerance: 10,
      latencyTolerance: 500,
      growthBoost: 1
    }
  };

  /* =========================
     🚀 MAIN ENGINE
  ========================= */
  static run(systemState = {}) {

    const start = performance.now?.() || Date.now();

    try {

      const safe = this.sanitize(systemState);

      const maturity = SystemMaturityEngine.evaluate(safe);

      const level = maturity?.level || "MVP";

      let features = FeatureFlagEngine.getFeatures(level);

      features = this.applyAdaptiveSafety(features, safe);

      this.learn(safe, maturity);

      this.autoOptimize();

      this.state.lastLevel = level;

      return {
        success: true,
        level,
        features,
        metrics: maturity.metrics,
        stability: this.state.stabilityScore,

        meta: {
          system: "SELF_LEARNING_AUTONOMOUS_CONTROL",
          historySize: this.state.history.length,
          timestamp: Date.now(),
          duration: Math.round((performance.now?.() || Date.now()) - start)
        }
      };

    } catch (error) {

      this.state.failures++;

      this.learnFailure(systemState, error);

      return this.rollback(error);
    }
  }

  /* =========================
     🧼 SAFE SANITIZATION (IMPROVED)
  ========================= */
  static sanitize(state) {

    if (!state || typeof state !== "object") {
      return this.emptyMetrics();
    }

    return {
      users: this.toNumber(state.users),
      revenue: this.toNumber(state.revenue),
      activity: this.toNumber(state.activity),
      errors: this.toNumber(state.errors),
      latency: this.toNumber(state.latency)
    };
  }

  /* =========================
     🔢 SAFE NUMBER PARSER
  ========================= */
  static toNumber(v) {

    const n = Number(v);
    return Number.isFinite(n) ? n : 0;
  }

  /* =========================
     📦 EMPTY STATE FALLBACK
  ========================= */
  static emptyMetrics() {

    return {
      users: 0,
      revenue: 0,
      activity: 0,
      errors: 0,
      latency: 0
    };
  }

  /* =========================
     🧠 LEARNING ENGINE (OPTIMIZED)
  ========================= */
  static learn(state, maturity) {

    const entry = {
      ...state,
      level: maturity?.level || "MVP",
      stability: this.state.stabilityScore,
      timestamp: Date.now()
    };

    this.state.history.push(entry);

    // 🧹 MEMORY MANAGEMENT OPTIMIZED
    if (this.state.history.length > 2000) {
      this.state.history.splice(0, 200); // faster batch cleanup
    }
  }

  /* =========================
     💥 FAILURE LEARNING
  ========================= */
  static learnFailure(state, error) {

    this.state.history.push({
      ...this.sanitize(state),
      type: "FAILURE",
      error: error?.message || "UNKNOWN_ERROR",
      timestamp: Date.now()
    });
  }

  /* =========================
     🧯 ADAPTIVE SAFETY LAYER
  ========================= */
  static applyAdaptiveSafety(features, state) {

    const t = this.state.thresholds;

    const unstable =
      state.errors > t.errorTolerance ||
      state.latency > t.latencyTolerance;

    if (!unstable) return features;

    // 🔥 SAFE MODE ACTIVATION
    return {
      ...features,

      vectorAI: false,
      legalAI: false,
      orchestration: false
    };
  }

  /* =========================
     📈 AUTO OPTIMIZATION ENGINE
  ========================= */
  static autoOptimize() {

    const history = this.state.history;

    if (history.length < 15) return;

    const recent = history.slice(-30);

    const avgErrors = this.average(recent, "errors");
    const avgLatency = this.average(recent, "latency");

    // 📉 ADAPTATION LOGIC (SMOOTHER)

    if (avgErrors < 1.5) {
      this.state.thresholds.errorTolerance++;
    }

    if (avgLatency < 180) {
      this.state.thresholds.latencyTolerance += 20;
    }

    if (avgErrors > 4) {
      this.state.thresholds.errorTolerance--;
    }

    // 🧯 HARD LIMITS (ANTI-DRIFT)
    this.state.thresholds.errorTolerance =
      this.clamp(this.state.thresholds.errorTolerance, 5, 50);

    this.state.thresholds.latencyTolerance =
      this.clamp(this.state.thresholds.latencyTolerance, 100, 2000);
  }

  /* =========================
     📊 UTILS (PERF OPTIMIZED)
  ========================= */
  static average(arr, key) {

    let sum = 0;

    for (let i = 0; i < arr.length; i++) {
      sum += arr[i]?.[key] || 0;
    }

    return sum / arr.length;
  }

  static clamp(value, min, max) {
    return Math.max(min, Math.min(max, value));
  }

  /* =========================
     🔁 ROLLBACK SYSTEM (IMPROVED)
  ========================= */
  static rollback(error) {

    return {
      success: false,
      level: "MVP",
      features: FeatureFlagEngine.getFeatures("MVP"),

      stability: this.state.stabilityScore,

      meta: {
        system: "SELF_LEARNING_AUTONOMOUS_CONTROL",
        rollback: true,
        error: error?.message || "SYSTEM_FAILURE",
        timestamp: Date.now()
      }
    };
  }

  /* =========================
     📊 INSPECT / DEBUG
  ========================= */
  static inspect() {

    return {
      state: this.state,
      health:
        this.state.stabilityScore > 70
          ? "HEALTHY"
          : "DEGRADED"
    };
  }
}

