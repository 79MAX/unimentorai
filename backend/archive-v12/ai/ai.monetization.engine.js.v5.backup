/**
 * =========================================
 * UniMentorAI - AI MONETIZATION ENGINE V3
 * CORE SAAS DECISION LAYER
 * =========================================
 *
 * This module is the "brain" between:
 * - AI requests
 * - Stripe plans
 * - Usage limits
 * - Cost engine
 * - Revenue tracking
 * =========================================
 */

import { canUseAI } from "../security/ai.guard.js";
import { trackAIUsage } from "../billing/stripe.usage.service.js";
import { getPlan } from "../billing/stripe.plans.js";
import { getCostSummary } from "./ai.cost.engine.js";

/* =========================
   MAIN AI MONETIZATION FLOW
========================= */
export function processAIRequest({
  userId,
  question,
  intent,
  level = "beginner",
  language = "fr",
  plan = "FREE",
  inputTokens = 0,
  outputTokens = 0,
}) {
  // =========================
  // 1. GET PLAN CONFIG
  // =========================
  const planConfig = getPlan(plan);

  // =========================
  // 2. AI GUARD CHECK (SECURITY + LIMITS)
  // =========================
  const access = canUseAI(userId, plan);

  if (!access.allowed) {
    return {
      success: false,
      code: access.reason || "AI_BLOCKED",
      remaining: access.remaining,
      limit: access.limit,
      upgradeRequired: plan === "FREE",
    };
  }

  // =========================
  // 3. COST CALCULATION
  // =========================
  const cost = getCostSummary({
    inputTokens,
    outputTokens,
    plan,
  });

  // =========================
  // 4. TRACK USAGE (STRIPE + ANALYTICS READY)
  // =========================
  const usageEvent = trackAIUsage({
    userId,
    intent,
    level,
    language,
    plan,
    tokens: inputTokens + outputTokens,
  });

  // =========================
  // 5. RESPONSE PAYLOAD (SAAS OUTPUT)
  // =========================
  return {
    success: true,

    data: {
      question,
      intent,
      level,
      language,

      // AI RESPONSE PLACEHOLDER (connected later)
      answer: null,

      // MONETIZATION DATA
      plan: planConfig.name,
      usage: usageEvent,
      cost,

      // LIMIT INFO
      remaining: access.remaining,

      timestamp: Date.now(),
    },
  };
}

/* =========================
   SIMPLE RESPONSE WRAPPER (FOR AI ROUTES)
========================= */
export function buildAIResponse({
  question,
  intent,
  level,
  language,
  answer,
}) {
  return {
    success: true,
    data: {
      question,
      intent,
      level,
      language,
      answer,
      timestamp: Date.now(),
    },
  };
}