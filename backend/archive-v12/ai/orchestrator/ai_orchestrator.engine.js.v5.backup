/**
 * 🧠 AI ORCHESTRATOR ENGINE — SYSTEM KERNEL (PRO MAX)
 * Level: OpenAI / Stripe / Meta AI Infra Architecture
 */

import EventEmitter from "events";
import { AiAdminBrainEngine } from "../core/ai_admin_brain.engine.js";
import { AiCeoBrainEngine } from "../core/ai_ceo_brain.engine.js";
import { AiSelfLearningLoop } from "../self_learning/self_learning.loop.js";

export class AiOrchestratorEngine extends EventEmitter {

  /* =========================
     🧠 STATE (IMMUTABLE SAFE CORE)
  ========================= */
  static state = {
    health: 100,
    lastRun: 0,
    events: 0,
    errors: 0,
    latencyBuffer: []
  };

  /* =========================
     🚀 MAIN PIPELINE (CLEAN ORCHESTRATION)
  ========================= */
  static async run(payload = {}) {

    const start = performance.now?.() || Date.now();
    this.state.events++;

    const { users = [], payments = [], aiLogs = [], courses = [] } = payload;

    try {

      /* =========================
         🧠 PARALLEL INTELLIGENCE LAYER
      ========================= */
      const [admin, ceo] = await Promise.all([
        this.safe(() => AiAdminBrainEngine.analyze({ users, payments, aiLogs, courses })),
        this.safe(() => AiCeoBrainEngine.decide({ users, payments, aiLogs, courses }))
      ]);

      /* =========================
         🔁 SELF LEARNING FEEDBACK LOOP
      ========================= */
      this.safe(() => AiSelfLearningLoop.learn({ admin, ceo }));

      /* =========================
         📊 HEALTH ENGINE (WEIGHTED MODEL)
      ========================= */
      const health = this.computeHealth(admin, ceo);
      this.state.health = health;
      this.state.lastRun = Date.now();

      /* =========================
         ⚡ LATENCY ENGINE (AVG BUFFER OPTIMIZED)
      ========================= */
      const latency = (performance.now?.() || Date.now()) - start;
      this.trackLatency(latency);

      const output = this.buildOutput({ admin, ceo, health, latency });

      this.emit("AI_EVENT", output);

      return output;

    } catch (err) {

      this.state.errors++;

      this.emit("AI_ERROR", {
        error: err?.message || "UNKNOWN_ERROR",
        timestamp: Date.now()
      });

      return {
        error: true,
        message: err?.message || "UNKNOWN_ERROR"
      };
    }
  }

  /* =========================
     🧠 SAFE WRAPPER (NO CRASH PROPAGATION)
  ========================= */
  static async safe(fn) {
    try {
      return await fn();
    } catch {
      this.state.errors++;
      return null;
    }
  }

  /* =========================
     📊 HEALTH ENGINE (WEIGHTED INTELLIGENCE SCORE)
  ========================= */
  static computeHealth(admin, ceo) {

    let score = 50;

    // CEO SIGNALS
    const risk = ceo?.risk;
    if (risk === "LOW") score += 20;
    else if (risk === "CRITICAL") score -= 35;

    // GROWTH SIGNALS
    const growth = admin?.growth?.trend;
    if (growth === "EXPLOSIVE") score += 25;
    else if (growth === "CRITICAL") score -= 20;

    // REVENUE SIGNALS
    if (admin?.revenue?.trend === "UP") score += 15;

    return Math.max(0, Math.min(100, Math.round(score)));
  }

  /* =========================
     ⚡ LATENCY ENGINE (ROLLING WINDOW)
  ========================= */
  static trackLatency(latency) {

    this.state.latencyBuffer.push(latency);

    // Rolling window (performance safe)
    if (this.state.latencyBuffer.length > 30) {
      this.state.latencyBuffer.shift();
    }
  }

  /* =========================
     📊 OUTPUT BUILDER (NORMALIZED API RESPONSE)
  ========================= */
  static buildOutput({ admin, ceo, health, latency }) {

    return {
      timestamp: this.state.lastRun,
      latency,
      health,

      admin,
      ceo,

      meta: {
        mode: health > 75 ? "OPTIMAL"
            : health > 50 ? "STABLE"
            : "DEGRADED",

        events: this.state.events,
        errors: this.state.errors
      }
    };
  }

  /* =========================
     📊 METRICS (ADMIN DASHBOARD READY)
  ========================= */
  static getMetrics() {

    const buffer = this.state.latencyBuffer;

    const avgLatency = buffer.length
      ? buffer.reduce((a, b) => a + b, 0) / buffer.length
      : 0;

    return {
      health: this.state.health,
      events: this.state.events,
      errors: this.state.errors,
      avgLatency: Math.round(avgLatency),
      lastRun: this.state.lastRun
    };
  }
}

