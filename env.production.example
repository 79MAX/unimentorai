# UniMentorAI - Configuration de Production Sécurisée
# ⚠️ NE JAMAIS COMMITER CE FICHIER ⚠️
# ⚠️ AJOUTER À .gitignore ⚠️

# ===== FIREBASE CONFIGURATION =====
FIREBASE_PROJECT_ID=unimentorai-prod
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_STORAGE_BUCKET=unimentorai-prod.appspot.com

# ===== PAYMENT GATEWAYS =====
# Stripe
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# Kkiapay
KKIAPAY_PUBLIC_KEY=your_kkiapay_public_key_here
KKIAPAY_PRIVATE_KEY=your_kkiapay_private_key_here
KKIAPAY_WEBHOOK_SECRET=your_kkiapay_webhook_secret_here

# Wise
WISE_API_KEY=your_wise_api_key_here
WISE_WEBHOOK_SECRET=your_wise_webhook_secret_here

# ===== AI SERVICES =====
# OpenAI
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_ORGANIZATION_ID=your_openai_organization_id_here

# Google Translate
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here
GOOGLE_TRANSLATE_PROJECT_ID=your_google_translate_project_id_here

# ===== SECURITY & ENCRYPTION =====
# Clé de chiffrement AES-256 (32 caractères)
ENCRYPTION_KEY=your_32_character_encryption_key_here
# Clé JWT pour les tokens
JWT_SECRET=your_jwt_secret_key_here
# Clé pour l'authentification biométrique
BIOMETRIC_SECRET=your_biometric_secret_key_here

# ===== ENVIRONMENT CONFIGURATION =====
ENVIRONMENT=production
DEBUG_MODE=false
LOG_LEVEL=error
ENABLE_CRASHLYTICS=true
ENABLE_ANALYTICS=true

# ===== PERFORMANCE & CACHE =====
CACHE_DURATION_HOURS=24
MAX_TRANSLATIONS_PER_COURSE=2
MAX_CACHE_SIZE_MB=100
MAX_FILE_SIZE_MB=10
CONNECTION_TIMEOUT_SECONDS=30

# ===== GDPR & PRIVACY =====
DATA_RETENTION_DAYS=365
ANONYMIZE_LOGS=true
ENABLE_DATA_EXPORT=true
ENABLE_DATA_DELETION=true
COOKIE_CONSENT_REQUIRED=true

# ===== NOTIFICATIONS =====
FCM_SERVER_KEY=your_fcm_server_key_here
APNS_KEY_ID=your_apns_key_id_here
APNS_TEAM_ID=your_apns_team_id_here
APNS_BUNDLE_ID=com.unimentorai.app

# ===== MONITORING & ANALYTICS =====
SENTRY_DSN=your_sentry_dsn_here
MIXPANEL_TOKEN=your_mixpanel_token_here
GOOGLE_ANALYTICS_ID=your_google_analytics_id_here

# ===== BACKUP & RECOVERY =====
BACKUP_ENABLED=true
BACKUP_FREQUENCY_HOURS=24
RECOVERY_ENABLED=true
DATA_EXPORT_ENABLED=true

# ===== RATE LIMITING =====
MAX_REQUESTS_PER_MINUTE=60
MAX_REQUESTS_PER_HOUR=1000
MAX_REQUESTS_PER_DAY=10000

# ===== FEATURE FLAGS =====
ENABLE_CHATBOT=true
ENABLE_MENTORING=true
ENABLE_WEBINARS=true
ENABLE_CERTIFICATES=true
ENABLE_ENTERPRISE=true

# ===== API LIMITS =====
MAX_COURSES_PER_USER=50
MAX_STEPS_PER_COURSE=100
MAX_TRANSLATIONS_PER_COURSE=2
MAX_CORRECTIONS_PER_TRANSLATION=10

# ===== SECURITY POLICIES =====
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# ===== COMPLIANCE =====
GDPR_COMPLIANT=true
CCPA_COMPLIANT=true
SOC2_COMPLIANT=true
ISO27001_COMPLIANT=true






