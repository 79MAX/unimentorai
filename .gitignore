@'
# =========================================================
# UNIMENTORAI OBSERVABILITY SAAS PLATFORM
# ENTERPRISE GITIGNORE v2
# =========================================================

# =========================================================
# ENVIRONMENT / SECRETS
# =========================================================

.env
.env.*
!.env.example

# =========================================================
# NODE / REACT / VITE
# =========================================================

node_modules/
dist/
build/
.next/
out/
coverage/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

vite.svg

# =========================================================
# TYPESCRIPT
# =========================================================

*.tsbuildinfo

# =========================================================
# LOGS
# =========================================================

logs/
*.log

# =========================================================
# CACHE
# =========================================================

.cache/
.parcel-cache/
.eslintcache

# =========================================================
# TEMP FILES
# =========================================================

tmp/
temp/
*.tmp
*.temp
*.swp

# =========================================================
# OS FILES
# =========================================================

.DS_Store
Thumbs.db
desktop.ini

# =========================================================
# IDE / EDITORS
# =========================================================

.idea/
.vscode/
*.iml

# =========================================================
# FLUTTER / DART
# =========================================================

.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub/
.pub-cache/

# =========================================================
# ANDROID
# =========================================================

android/.gradle/
android/app/debug/
android/app/profile/
android/app/release/

# =========================================================
# IOS
# =========================================================

ios/Pods/
ios/.symlinks/
ios/Flutter/.last_build_id

# =========================================================
# OBSERVABILITY ENGINE
# =========================================================

backend/storage/
backend/logs/
backend/tmp/
backend/cache/

# =========================================================
# DATABASES
# =========================================================

*.sqlite
*.sqlite3
*.db

# =========================================================
# TESTING
# =========================================================

coverage/
playwright-report/
test-results/

# =========================================================
# DOCKER
# =========================================================

.docker/

# =========================================================
# DEPLOYMENT
# =========================================================

.vercel/
.netlify/

# =========================================================
# MISC
# =========================================================

*.pid
*.seed
*.pid.lock
'@ | Set-Content ".gitignore"

Write-Host "🚀 ENTERPRISE .gitignore v2 UPDATED"
node_modules
node_modules

# Secrets and environment archives
_env_archive/
.env
.env.*
*.env
