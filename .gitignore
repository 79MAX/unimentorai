@'
# =========================================================
# UNIMENTORAI OBSERVABILITY SAAS PLATFORM
# ENTERPRISE GITIGNORE v3
# SECURITY HARDENED
# =========================================================


# =========================================================
# ENVIRONMENT / SECRETS
# =========================================================

.env
.env.*
!.env.example
*.env

# API KEYS / CERTIFICATES
*.key
*.pem
*.crt
*.p12
*.jks


# =========================================================
# NODE / REACT / VITE
# =========================================================

node_modules/
dist/
build/
.next/
out/
coverage/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

vite.svg


# =========================================================
# TYPESCRIPT
# =========================================================

*.tsbuildinfo


# =========================================================
# LOGS
# =========================================================

logs/
*.log
backend/logs/


# =========================================================
# CACHE / TEMP
# =========================================================

.cache/
.parcel-cache/
.eslintcache

tmp/
temp/
*.tmp
*.temp
*.swp


# =========================================================
# OS
# =========================================================

.DS_Store
Thumbs.db
desktop.ini


# =========================================================
# IDE
# =========================================================

.idea/
.vscode/
*.iml


# =========================================================
# FLUTTER
# =========================================================

.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub/
.pub-cache/

build/


# =========================================================
# ANDROID / IOS
# =========================================================

android/.gradle/
android/app/debug/
android/app/profile/
android/app/release/

ios/Pods/
ios/.symlinks/
ios/Flutter/.last_build_id


# =========================================================
# DATABASE
# =========================================================

*.sqlite
*.sqlite3
*.db


# =========================================================
# TEST
# =========================================================

playwright-report/
test-results/


# =========================================================
# DOCKER / DEPLOYMENT
# =========================================================

.docker/
.vercel/
.netlify/


# =========================================================
# UNIMENTORAI SECURITY
# =========================================================

_env_archive/
archive/
archives/

guardian-backups/
snapshots/

*_backup/
*_backup.*

UNIMENTORAI_AUDIT/
audit/
reports/


# =========================================================
# LARGE GENERATED FILES
# =========================================================

*.zip
*.tar
*.gz

*.csv
*.jsonl


# =========================================================
# PROCESS FILES
# =========================================================

*.pid
*.pid.lock
*.seed


'@ | Set-Content ".gitignore"

Write-Host "🚀 ENTERPRISE .gitignore v3 SECURITY HARDENED UPDATED"
# Runtime storage
backend/storage/