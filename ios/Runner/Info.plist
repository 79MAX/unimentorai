<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Informations de base -->
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>UniMentorAI</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>UniMentorAI</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	
	<!-- Interface utilisateur -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	
	<!-- Performance -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	
	<!-- Sécurité et confidentialité -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>firebase.googleapis.com</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<false/>
				<key>NSExceptionMinimumTLSVersion</key>
				<string>TLSv1.2</string>
			</dict>
			<key>unimentorai.com</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<false/>
				<key>NSExceptionMinimumTLSVersion</key>
				<string>TLSv1.2</string>
			</dict>
		</dict>
	</dict>
	
	<!-- Permissions et capacités -->
	<key>NSCameraUsageDescription</key>
	<string>UniMentorAI utilise la caméra pour scanner des QR codes et prendre des photos de profil.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>UniMentorAI utilise le microphone pour les enregistrements audio dans les cours.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>UniMentorAI accède à votre photothèque pour sélectionner des images de profil.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>UniMentorAI utilise votre localisation pour personnaliser les cours selon votre région.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>UniMentorAI utilise Face ID pour sécuriser votre compte avec l'authentification biométrique.</string>
	
	<!-- Notifications -->
	<key>UIBackgroundModes</key>
	<array>
		<string>background-processing</string>
		<string>remote-notification</string>
	</array>
	
	<!-- Liens profonds -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.unimentorai.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>unimentorai</string>
				<string>https</string>
			</array>
		</dict>
	</array>
	
	<!-- Configuration Firebase -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<false/>
	
	<!-- Configuration des notifications -->
	<key>UNUserNotificationCenterDelegate</key>
	<true/>
	
	<!-- Configuration de la sécurité -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	
	<!-- Configuration de l'App Store -->
	<key>ITSEncryptionExportComplianceCode</key>
	<string>ITSAppUsesNonExemptEncryption</string>
	
	<!-- Configuration de la confidentialité -->
	<key>NSUserTrackingUsageDescription</key>
	<string>UniMentorAI utilise le suivi pour améliorer votre expérience d'apprentissage personnalisée.</string>
	
	<!-- Configuration des réseaux sociaux -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>https</string>
		<string>http</string>
		<string>mailto</string>
		<string>tel</string>
	</array>
</dict>
</plist>