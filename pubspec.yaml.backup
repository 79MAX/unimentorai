name: unimentorai
description: Application de formation certifiante et de reverse mentoring automatisée.
publish_to: "none"
version: 1.0.0+1

environment:
  sdk: ">=3.4.0 <4.0.0"

dependencies:
  flutter:
    sdk: flutter
  flutter_localizations:
    sdk: flutter

  # Core Flutter
  cupertino_icons: ^1.0.8
  
  # Firebase - Latest versions
  firebase_core: ^3.6.0
  firebase_auth: ^5.3.1
  cloud_firestore: ^5.4.3
  firebase_storage: ^12.3.2
  firebase_performance: ^0.10.0+7
  firebase_functions: ^5.1.3
  firebase_analytics: ^11.3.3
  firebase_crashlytics: ^4.1.3
  
  # State Management - Updated
  provider: ^6.1.2
  flutter_bloc: ^8.1.6
  riverpod: ^2.6.1
  flutter_riverpod: ^2.6.1
  
  # HTTP & API - Updated
  http: ^1.2.2
  dio: ^5.7.0
  
  # Localization
  intl: ^0.19.0
  
  # File handling
  file_picker: ^8.1.2
  path_provider: ^2.1.4
  
  # UI & Navigation - Updated
  url_launcher: ^6.3.1
  flutter_svg: ^2.0.15
  cached_network_image: ^3.4.1
  shimmer: ^3.0.0
  
  # Storage & Preferences - Updated
  shared_preferences: ^2.3.2
  flutter_secure_storage: ^9.2.2
  hive: ^2.2.3
  hive_flutter: ^1.1.0
  
  # Notifications - Updated
  flutter_local_notifications: ^18.0.1
  firebase_messaging: ^15.1.3
  
  # Connectivity
  connectivity_plus: ^6.0.5
  
  # UI Components - Updated
  fluttertoast: ^8.2.8
  lottie: ^3.1.2
  flutter_staggered_animations: ^1.1.1
  
  # Security & Encryption - Updated
  crypto: ^3.0.5
  encrypt: ^5.0.3
  local_auth: ^2.3.0
  
  # Payment Integration - Updated
  stripe_payment: ^1.1.4
  paypal_sdk: ^1.0.0
  
  # Translation - Custom implementation
  # google_translate: ^0.1.5  # Removed - will use custom implementation
  
  # Image handling - Updated
  image_picker: ^1.1.2
  image_cropper: ^8.0.2
  
  # QR Code
  qr_flutter: ^4.1.0
  qr_code_scanner: ^1.0.1
  
  # Charts & Analytics
  fl_chart: ^0.69.0
  
  # PDF Generation
  pdf: ^3.11.1
  printing: ^5.13.2
  
  # Environment - Updated
  flutter_dotenv: ^5.1.0
  
  # New dependencies for optimization
  equatable: ^2.0.5
  json_annotation: ^4.9.0
  freezed_annotation: ^2.4.4
  go_router: ^14.6.2
  auto_route: ^8.3.0
  injectable: ^2.4.4
  get_it: ^8.0.0
  logger: ^2.4.0
  permission_handler: ^11.3.1
  device_info_plus: ^10.1.2
  package_info_plus: ^8.0.2
  flutter_launcher_icons: ^0.13.1
  flutter_native_splash: ^2.4.1

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^4.0.0
  integration_test:
    sdk: flutter
  
  # Testing - Updated
  mockito: ^5.4.4
  bloc_test: ^9.1.7
  golden_toolkit: ^0.15.0
  test: ^1.25.8
  coverage: ^1.8.0
  mocktail: ^1.0.4
  
  # Code Generation - Updated
  build_runner: ^2.4.13
  flutter_gen_runner: ^5.4.0
  json_serializable: ^6.8.0
  hive_generator: ^2.0.1
  freezed: ^2.5.7
  auto_route_generator: ^8.3.0
  injectable_generator: ^2.6.2
  
  # Linting - Updated
  very_good_analysis: ^6.0.0

flutter_gen:
  output: lib/gen
  integrations:
    flutter_svg: true

flutter:
  uses-material-design: true

  assets:
    - assets/images/
    - assets/icons/
    - assets/logos/
    - assets/animations/
    - .env

  fonts:
    - family: Poppins
      fonts:
        - asset: assets/fonts/Poppins-Regular.ttf
        - asset: assets/fonts/Poppins-Bold.ttf
          weight: 700
        - asset: assets/fonts/Poppins-Medium.ttf
          weight: 500
        - asset: assets/fonts/Poppins-SemiBold.ttf
          weight: 600
