{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,

    "types": ["vite/client"]
  },

  "include": ["src"],
  "exclude": ["node_modules"]
}